{
  "meta": {
    "version": "2026-04-02",
    "purpose": "Squadmaker MVP implementation should iterate against explicit repository and application harness scenarios.",
    "owner": "product-engineering"
  },
  "repositoryHarness": {
    "goals": [
      "문서 우선순위와 제품 규칙을 저장소에서 반복 검증 가능한 구조로 고정한다.",
      "향후 기능 구현이 같은 시나리오 집합을 기준으로 움직이도록 만든다.",
      "검증 명령과 제품 시나리오의 연결 상태를 한 번에 점검한다."
    ],
    "requiredDocs": [
      "AGENTS.md",
      "docs/PRODUCT_SENSE.md",
      "docs/ARCHITECTURE.md",
      "docs/DOMAIN.md",
      "docs/FRONTEND.md",
      "docs/DESIGN.md",
      "docs/RELIABILITY.md",
      "docs/SECURITY.md"
    ],
    "validationCommands": [
      {
        "id": "lint",
        "command": "npm run lint",
        "purpose": "Next.js, TypeScript, Tailwind surface linting",
        "category": "static-check"
      },
      {
        "id": "typecheck",
        "command": "npm run typecheck",
        "purpose": "Server/component/shared harness typing",
        "category": "static-check"
      },
      {
        "id": "build",
        "command": "npm run build",
        "purpose": "Application route/build integrity check",
        "category": "build-check"
      },
      {
        "id": "repo-harness",
        "command": "npm run harness:repo",
        "purpose": "Harness metadata and linked document validation",
        "category": "harness-check"
      },
      {
        "id": "scenario-harness",
        "command": "npm run harness:scenarios",
        "purpose": "Scenario contract and linked fixture validation",
        "category": "harness-check"
      },
      {
        "id": "test-harness",
        "command": "npm run test:harness",
        "purpose": "Repository harness suite entrypoint",
        "category": "harness-check"
      },
      {
        "id": "test-playwright",
        "command": "npm run test:playwright",
        "purpose": "Browser-level route rendering and interaction validation",
        "category": "harness-check"
      },
      {
        "id": "test",
        "command": "npm run test",
        "purpose": "Combined harness metadata and Playwright suite entrypoint",
        "category": "harness-check"
      }
    ],
    "workflowRequirements": [
      "비사소한 변경은 active exec-plan을 먼저 갱신한다.",
      "UI 변경은 스크린샷 검증 체크리스트를 포함한다.",
      "UI 변경의 스크린샷은 Playwright 기반 visual test 또는 같은 수준의 자동 캡처로 남긴다.",
      "모든 비사소한 변경은 execution log를 남긴다.",
      "테스트 통과라는 표현은 실제 기능 테스트와 하네스 검증을 구분해 기록한다."
    ],
    "handoffContract": {
      "requiredScenarioFields": [
        "priority",
        "owner",
        "status",
        "linkedExecPlan",
        "linkedDocs",
        "assertions",
        "manualChecks",
        "expectedResults",
        "verification.checks",
        "verification.targets",
        "handoff.dependsOn",
        "handoff.deliverables",
        "handoff.readyWhen",
        "handoff.nextWorkstream"
      ],
      "requiredWorkArtifactNotes": [
        "변경한 문서와 코드 경로",
        "실행한 검증 명령",
        "다음 작업자가 바로 이어받을 입력 조건",
        "남은 blocker 또는 open question"
      ]
    },
    "ciGate": {
      "workflowPath": ".github/workflows/harness-ci.yml",
      "requiredCommands": [
        "npm run harness:repo",
        "npm run harness:scenarios",
        "npm run test",
        "npm run typecheck",
        "npm run lint",
        "npm run build"
      ]
    },
    "gates": [
      "scenario id must be unique",
      "linked docs must exist",
      "formations must stay inside the MVP support list",
      "application harness route must stay discoverable from the landing page",
      "scenario handoff contract must be complete",
      "scenario expected results and verification targets must be complete",
      "test:harness is metadata validation, not the full future test suite",
      "npm run test must include browser-level Playwright verification"
    ]
  },
